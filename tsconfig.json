{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        // Inherit all base options
        "rootDir": ".",
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "Node16",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "ES2022",
        "module": "Node16",
        "lib": [
            "ES2022",
            "dom"
        ],
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "baseUrl": ".",
        // Add strict type checking to catch build-time errors in IDE
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": false, // Allow undefined properties in classes
        "noImplicitThis": true,
        "alwaysStrict": true,
        "noUnusedLocals": false, // Allow unused locals (ESLint handles this)
        "noUnusedParameters": false, // Allow unused parameters (ESLint handles this)
        "exactOptionalPropertyTypes": false, // Too strict for current codebase
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": false, // Too strict for current codebase
        "noImplicitOverride": true,
        // JSX support
        "jsx": "react-jsx",
        "jsxImportSource": "react",
    },
    // Include production source for strict checking. Build/dev scripts
    // and benchmark runners run via tsx and have their own looser
    // tsconfigs (scripts/tsconfig.json, benchmarks/tsconfig.scripts.json) —
    // typecheck those via `npm run typecheck:scripts` /
    // `npm run typecheck:benchmarks`.
    "include": [
        "packages/*/src/**/*"
    ],
    // Exclude generated and external files
    "exclude": [
        "node_modules",
        "tmp",
        "dist",
        "coverage",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*.d.ts",
        "**/*.config.ts",
        "**/*.config.js"
    ]
}