# Code Owners
#
# Used by GitHub for automatic PR review requests + AI-assistant
# discoverability of "who owns what". A glob further down overrides matches
# further up — broad rules first, specific overrides last.

# Global default — single-maintainer fleet, everything is mine.
* @ofri-peretz

# Workspace folders (wildcard patterns so adding a new plugin doesn't
# require touching this file).
/packages/eslint-plugin-*/   @ofri-peretz
/packages/eslint-*/          @ofri-peretz
/packages/*-mcp/             @ofri-peretz
/packages/interlace-*/       @ofri-peretz
/apps/                       @ofri-peretz
/tools/                      @ofri-peretz
/benchmarks/                 @ofri-peretz

# Top-level docs.
README.md          @ofri-peretz
CONTRIBUTING.md    @ofri-peretz
ARCHITECTURE.md    @ofri-peretz
ROADMAP.md         @ofri-peretz
/docs/             @ofri-peretz

# Repo plumbing — changes here affect how the whole monorepo builds,
# tests, releases, or behaves. Always require review.
/.github/                 @ofri-peretz
/.github/workflows/       @ofri-peretz
/.changeset/              @ofri-peretz
/scripts/                 @ofri-peretz
/package.json             @ofri-peretz
/package-lock.json        @ofri-peretz
/turbo.json               @ofri-peretz
/tsconfig.base.json       @ofri-peretz
/eslint.config.mjs        @ofri-peretz
/commitlint.config.mjs    @ofri-peretz
/.nvmrc                   @ofri-peretz
