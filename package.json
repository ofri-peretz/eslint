{
  "name": "interlace-monorepo",
  "version": "1.0.0",
  "description": "Open-source tools and libraries for JavaScript & TypeScript ecosystems - ESLint plugins with LLM-optimized rules, utilities, and CLI tools in a Turborepo monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*",
    "benchmarks"
  ],
  "packageManager": "npm@11.6.2",
  "main": "index.js",
  "homepage": "https://github.com/ofri-peretz/eslint#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofri-peretz/eslint.git"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "lefthook install",
    "ci:local": "lefthook run pre-push --all-files --force",
    "lint:workflows": "tsx scripts/lint-workflows.ts",
    "lint:workflows:actionlint": "actionlint",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "release:status": "tsx scripts/release-status.ts",
    "release:reconcile": "tsx scripts/reconcile-tags.ts",
    "release:reconcile:backfill": "tsx scripts/reconcile-tags.ts --backfill-missing",
    "release:reconcile:cleanup": "tsx scripts/reconcile-tags.ts --cleanup-orphans --confirm",
    "release:reconcile:releases": "tsx scripts/reconcile-tags.ts --create-releases",
    "release:notes": "tsx scripts/extract-changelog.ts",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=docs",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "test": "turbo run test",
    "test:affected": "turbo run test --affected",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "typecheck:benchmarks": "tsc --noEmit -p benchmarks/tsconfig.scripts.json",
    "release": "gh workflow run release.yml --ref main",
    "release:dry-run": "gh workflow run release.yml --ref main -f dry-run=true",
    "ci:trigger": "gh workflow run ci.yml --ref local-playground-app && echo '✅ Workflow triggered!'",
    "ci:status": "tsx scripts/ci-status.ts",
    "ci": "tsx scripts/ci-status.ts",
    "delete-branches": "bash scripts/delete-branches.sh",
    "sync-tags": "tsx scripts/sync-git-tags.ts",
    "sync-tags:dry-run": "tsx scripts/sync-git-tags.ts --dry-run",
    "check-links": "tsx scripts/check-markdown-links.ts",
    "check-versions": "tsx scripts/check-version-alignment.ts",
    "check-source-versions": "tsx scripts/check-source-version-sync.ts",
    "check-stale-artifacts": "tsx scripts/check-stale-build-artifacts.ts",
    "sync-source-versions": "tsx scripts/sync-source-versions.ts",
    "setup-branch-protection": "bash scripts/setup-branch-protection.sh",
    "benchmark": "tsx scripts/benchmark-plugin.ts",
    "benchmark:json": "tsx scripts/benchmark-plugin.ts --json",
    "stats:eslint-versions": "tsx scripts/fetch-eslint-version-stats.ts",
    "stats:eslint-versions:json": "tsx scripts/fetch-eslint-version-stats.ts --json --out=benchmark-results/eslint-version-stats.json",
    "devto:publish": "tsx scripts/devto-publish.ts",
    "devto:update-tags": "tsx scripts/devto-update-tags.ts",
    "oxlint": "oxlint --config .oxlintrc.json apps/ packages/ scripts/ tools/",
    "oxlint:interlace": "oxlint --config .oxlintrc.experimental.json packages/",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules' '#**/dist'",
    "audit:portability": "tsx scripts/audit-rule-portability.ts",
    "audit:portability:ci": "tsx scripts/audit-rule-portability.ts --ci",
    "audit:portability:baseline": "tsx scripts/audit-rule-portability.ts --write-baseline",
    "oxlint:shims": "tsx scripts/generate-oxlint-shims.ts",
    "oxlint:shims:check": "tsx scripts/generate-oxlint-shims.ts --check",
    "oxlint:shims:verify": "tsx scripts/verify-oxlint-shims.ts",
    "oxlint:verify-runtime": "tsx scripts/verify-oxlint-runtime.ts",
    "oxlint:verify-runtime:update": "tsx scripts/verify-oxlint-runtime.ts --update",
    "audit:meta": "tsx scripts/audit-rule-meta-completeness.ts",
    "audit:meta:strict": "tsx scripts/audit-rule-meta-completeness.ts --strict",
    "audit:cwe-rendering": "tsx scripts/audit-cwe-rendering.ts",
    "codemod:lift-cwe": "tsx scripts/codemod-lift-cwe-to-meta-docs.ts",
    "codemod:lift-cwe:apply": "tsx scripts/codemod-lift-cwe-to-meta-docs.ts --apply",
    "audit:changelogs": "tsx scripts/generate-changelogs.ts --check",
    "generate:tests": "tsx scripts/generate-rule-tests.ts",
    "benchmark:score": "tsx benchmarks/score.ts",
    "benchmark:ci": "tsx benchmarks/score.ts --ci --threshold 80",
    "quality": "npm run oxlint && npm run audit:portability:ci && npm run oxlint:shims:check && npm run ilb:oxlint-parity:cached && npx turbo run test && npm run lint:md && npm run lint:fixtures && npm run ilb:validate-results && npm run ilb:flagship:smoke && npm run audit:changelogs",
    "audit:rules": "tsx scripts/audit-rule.ts --fleet",
    "audit:rule": "tsx scripts/audit-rule.ts",
    "coverage:gaps": "tsx scripts/coverage-gap-analysis.ts",
    "bench:devkit": "npx vitest bench --config packages/eslint-devkit/vitest.config.mts",
    "ilb:wild": "tsx scripts/ilb-wild.ts",
    "ilb:wild:list": "tsx scripts/ilb-wild.ts --list",
    "ilb:wild:results": "tsx scripts/ilb-wild.ts --results",
    "ilb:edge": "tsx scripts/ilb-wild.ts --fp-corpus",
    "ilb:cwe-corpus": "npm run ilb:cwe-corpus -w @interlace/benchmarks",
    "ilb:arena": "npm run ilb:arena -w @interlace/benchmarks",
    "ilb:arena:quality": "npm run ilb:arena-quality -w @interlace/benchmarks",
    "ilb:perf:import": "npm run ilb:perf-import -w @interlace/benchmarks",
    "ilb:ai": "npm run ilb:ai -w @interlace/benchmarks",
    "ilb:llm:tokens": "tsx benchmarks/suites/ilb-llm-tokens/runner.ts",
    "ilb:llm:fix": "tsx benchmarks/suites/ilb-llm-fix/runner.ts",
    "ilb:formatter": "tsx benchmarks/suites/ilb-formatter/runner.ts",
    "ilb:scorecard": "tsx scripts/ilb-scorecard.ts",
    "ilb:resource-profile": "tsx scripts/ilb-resource-profile.ts",
    "peer-health": "tsx scripts/fetch-peer-health.ts",
    "audit:cve-latency": "tsx scripts/audit-cve-rule-latency.ts",
    "audit:cve-latency:strict": "tsx scripts/audit-cve-rule-latency.ts --strict",
    "audit:api-surface": "tsx scripts/audit-api-surface.ts",
    "audit:api-surface:strict": "tsx scripts/audit-api-surface.ts --strict",
    "audit:stock-overlap": "tsx scripts/audit-stock-corpus-overlap.ts",
    "audit:stock-overlap:strict": "tsx scripts/audit-stock-corpus-overlap.ts --strict",
    "check:per-rule-budget": "tsx scripts/check-per-rule-budget.ts",
    "check:per-rule-budget:soft": "tsx scripts/check-per-rule-budget.ts --soft",
    "check:audit-freshness": "tsx scripts/check-audit-freshness.ts",
    "check:audit-freshness:soft": "tsx scripts/check-audit-freshness.ts --soft",
    "ilb:regression": "tsx scripts/ilb-regression-check.ts",
    "ilb:validate-fixtures": "npm run ilb:validate-fixtures -w @interlace/benchmarks",
    "ilb:validate-fixtures:strict": "npm run ilb:validate-fixtures:strict -w @interlace/benchmarks",
    "ilb:validate-results": "tsx scripts/ilb-validate-results.ts",
    "ilb:validate-results:strict": "tsx scripts/ilb-validate-results.ts --strict",
    "ilb:history-backfill": "tsx scripts/ilb-history-backfill.ts",
    "ilb:promotion-gate": "tsx scripts/ilb-promotion-gate.ts",
    "ilb:promotion-gate:explain": "tsx scripts/ilb-promotion-gate.ts --explain",
    "ilb:coverage": "tsx scripts/ilb-fixture-coverage.ts",
    "ilb:corpus-integrity": "tsx scripts/ilb-corpus-integrity.ts",
    "ilb:doc-test-alignment": "tsx scripts/ilb-doc-test-alignment.ts",
    "ilb:severity-audit": "tsx scripts/ilb-severity-audit.ts",
    "ilb:autofix": "tsx scripts/ilb-autofix-bench.ts",
    "ilb:determinism": "tsx benchmarks/suites/ilb-determinism/run.ts",
    "ilb:diff": "tsx benchmarks/suites/ilb-diff/run.ts",
    "ilb:oxlint-parity": "tsx benchmarks/suites/ilb-oxlint-parity/run.ts",
    "ilb:oxlint-parity:ci": "tsx benchmarks/suites/ilb-oxlint-parity/run.ts --ci",
    "ilb:oxlint-parity:cached": "tsx benchmarks/suites/ilb-oxlint-parity/run.ts --cached",
    "ilb:oxlint-parity:harvest": "tsx benchmarks/suites/ilb-oxlint-parity/harvest-fixtures.ts",
    "ilb:oxlint-parity:full": "npm run ilb:oxlint-parity:harvest && tsx benchmarks/suites/ilb-oxlint-parity/run.ts --corpus benchmarks/suites/ilb-oxlint-parity/harvested-fixtures --plugins pg,node-security,browser-security,secure-coding,crypto,jwt,express-security,mongodb-security,nestjs-security,lambda-security,vercel-ai-security --ci",
    "ilb:tsc-matrix": "tsx benchmarks/suites/ilb-tsc-matrix/run.ts",
    "ilb:node-matrix": "tsx benchmarks/suites/ilb-node-matrix/run.ts",
    "ilb:eslint-matrix": "tsx benchmarks/suites/ilb-eslint-matrix/run.ts",
    "ilb:parser-matrix": "tsx benchmarks/suites/ilb-parser-matrix/run.ts",
    "ilb:cache-matrix": "tsx benchmarks/suites/ilb-cache-matrix/run.ts",
    "ilb:confidence": "tsx benchmarks/suites/ilb-confidence/run.ts",
    "ilb:discover": "tsx benchmarks/suites/ilb-discover/run.ts",
    "ilb:evade": "tsx benchmarks/suites/ilb-evade/run.ts",
    "ilb:mappings:report": "tsx scripts/ilb-mappings-report.ts",
    "ilb:provenance": "tsx scripts/ilb-provenance.ts",
    "ilb:provenance:check": "tsx scripts/ilb-provenance.ts --check",
    "ilb:leaderboard:publish": "tsx scripts/ilb-leaderboard-publish.ts",
    "ilb:leaderboard:check": "tsx scripts/ilb-leaderboard-publish.ts --check",
    "ilb:diff:publish": "tsx scripts/ilb-diff-publish.ts",
    "scaffold:mcp": "tsx scripts/scaffold-mcp.ts",
    "ilb:mutate": "tsx benchmarks/suites/ilb-mutate/run.ts",
    "ilb:iso25010:report": "tsx scripts/ilb-iso25010-report.ts",
    "ilb:kappa": "tsx scripts/ilb-kappa.ts",
    "ilb:smoke": "tsx scripts/ilb-smoke.ts",
    "ilb:cve:synthesize": "tsx scripts/ilb-cve-synthesize.ts",
    "ilb:federated:aggregate": "tsx scripts/ilb-federated-aggregate.ts",
    "ilb:federated:check": "tsx scripts/ilb-federated-aggregate.ts --check",
    "ilb:mcp-test": "tsx scripts/ilb-mcp-test.ts",
    "docs:cwe-coverage": "tsx scripts/docs-cwe-coverage.ts",
    "docs:cwe-coverage:check": "tsx scripts/docs-cwe-coverage.ts --check",
    "ilb:fuzz": "tsx scripts/ilb-fuzz.ts",
    "ilb:stress-test": "tsx scripts/ilb-stress-test.ts",
    "ilb:stress-test-docs": "tsx scripts/ilb-stress-test-docs.ts",
    "ilb:doc-resync": "tsx scripts/ilb-doc-resync.ts",
    "lint:fixtures": "npm run ilb:validate-fixtures:strict",
    "fix:shallow": "tsx scripts/fix-shallow-tests.ts",
    "ilb:flagship": "tsx benchmarks/suites/ilb-flagship/run.ts",
    "ilb:flagship:scorecard": "tsx benchmarks/suites/ilb-flagship/scorecard.ts",
    "ilb:flagship:smoke": "tsx benchmarks/suites/ilb-flagship/smoke.ts",
    "oxlint:flagship": "oxlint -c .oxlintrc.flagship.json"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript",
    "linting",
    "llm-optimized",
    "ai-assistant",
    "code-quality",
    "static-analysis",
    "ast",
    "turborepo",
    "monorepo",
    "cli",
    "utilities",
    "security",
    "accessibility",
    "react",
    "performance",
    "mcp",
    "model-context-protocol",
    "github-copilot",
    "cursor-ai",
    "claude-ai",
    "auto-fix",
    "deterministic-fixes",
    "cwe",
    "vulnerability-detection"
  ],
