{
  "name": "eslint",
  "version": "1.0.0",
  "description": "Open-source tools and libraries for JavaScript & TypeScript ecosystems - ESLint plugins with LLM-optimized rules, utilities, and CLI tools in a Turborepo monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*",
    "benchmarks"
  ],
  "packageManager": "npm@11.6.2",
  "main": "index.js",
  "homepage": "https://github.com/ofri-peretz/eslint#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofri-peretz/eslint.git"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "husky",
    "lint:workflows": "actionlint",
    "build": "turbo run build",
    "build:affected": "turbo run build --affected",
    "test": "turbo run test",
    "test:affected": "turbo run test --affected",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "release": "gh workflow run release.yml --ref main",
    "release:dry-run": "gh workflow run release.yml --ref main -f dry-run=true",
    "ci:trigger": "gh workflow run ci.yml --ref local-playground-app && echo '✅ Workflow triggered!'",
    "ci:status": "tsx scripts/ci-status.ts",
    "ci": "tsx scripts/ci-status.ts",
    "delete-branches": "bash scripts/delete-branches.sh",
    "sync-tags": "tsx scripts/sync-git-tags.ts",
    "sync-tags:dry-run": "tsx scripts/sync-git-tags.ts --dry-run",
    "check-links": "tsx scripts/check-markdown-links.ts",
    "check-versions": "tsx scripts/check-version-alignment.ts",
    "check-source-versions": "tsx scripts/check-source-version-sync.ts",
    "sync-source-versions": "tsx scripts/sync-source-versions.ts",
    "setup-branch-protection": "bash scripts/setup-branch-protection.sh",
    "benchmark": "tsx scripts/benchmark-plugin.ts",
    "benchmark:json": "tsx scripts/benchmark-plugin.ts --json",
    "devto:publish": "tsx scripts/devto-publish.ts",
    "devto:update-tags": "tsx scripts/devto-update-tags.ts",
    "oxlint": "oxlint --config .oxlintrc.json packages/",
    "oxlint:interlace": "oxlint --config .oxlintrc.experimental.json packages/",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#packages/*/node_modules' '#**/dist'",
    "audit:portability": "node scripts/audit-rule-portability.mjs",
    "audit:changelogs": "node scripts/generate-changelogs.mjs --check",
    "generate:tests": "node scripts/generate-rule-tests.mjs",
    "benchmark:score": "node benchmarks/score.mjs",
    "benchmark:ci": "node benchmarks/score.mjs --ci --threshold 80",
    "quality": "npm run oxlint && npx turbo run test && npm run lint:md && npm run lint:fixtures && npm run audit:changelogs",
    "audit:rules": "node scripts/audit-rule.mjs --fleet",
    "audit:rule": "node scripts/audit-rule.mjs",
    "coverage:gaps": "node scripts/coverage-gap-analysis.mjs",
    "bench:devkit": "npx vitest bench --config packages/eslint-devkit/vitest.config.mts",
    "ilb:wild": "node scripts/ilb-wild.mjs",
    "ilb:wild:list": "node scripts/ilb-wild.mjs --list",
    "ilb:wild:results": "node scripts/ilb-wild.mjs --results",
    "ilb:edge": "node scripts/ilb-wild.mjs --fp-corpus",
    "ilb:juliet": "npm run ilb:juliet -w @interlace/benchmarks",
    "ilb:arena": "npm run ilb:arena -w @interlace/benchmarks",
    "ilb:arena:quality": "npm run ilb:arena-quality -w @interlace/benchmarks",
    "ilb:perf:import": "npm run ilb:perf-import -w @interlace/benchmarks",
    "ilb:ai": "npm run ilb:ai -w @interlace/benchmarks",
    "ilb:llm:tokens": "tsx benchmarks/suites/ilb-llm-tokens/runner.ts",
    "ilb:llm:fix": "tsx benchmarks/suites/ilb-llm-fix/runner.ts",
    "ilb:scorecard": "tsx scripts/ilb-scorecard.ts",
    "ilb:regression": "tsx scripts/ilb-regression-check.ts",
    "ilb:audit": "node scripts/ilb-audit.mjs",
    "ilb:validate-fixtures": "npm run ilb:validate-fixtures -w @interlace/benchmarks",
    "ilb:validate-fixtures:strict": "npm run ilb:validate-fixtures:strict -w @interlace/benchmarks",
    "ilb:coverage": "node scripts/ilb-fixture-coverage.mjs",
    "lint:fixtures": "npm run ilb:validate-fixtures:strict",
    "fix:shallow": "node scripts/fix-shallow-tests.mjs"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "typescript",
    "linting",
    "llm-optimized",
    "ai-assistant",
    "code-quality",
    "static-analysis",
    "ast",
    "turborepo",
    "monorepo",
    "cli",
    "utilities",
    "security",
    "accessibility",
    "react",
    "performance",
    "mcp",
    "model-context-protocol",
    "github-copilot",
    "cursor-ai",
    "claude-ai",
    "auto-fix",
    "deterministic-fixes",
    "cwe",
    "vulnerability-detection"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@eslint/js": "^9.39.2",
    "@middy/core": "^6.4.5",
    "@middy/http-cors": "^6.4.5",
    "@middy/http-security-headers": "^6.4.5",
    "@middy/validator": "^6.4.5",
    "@nestjs/common": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "^1.15.11",
    "@swc/helpers": "^0.5.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "24.9.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "add": "^2.0.6",
    "ai": "^5.0.124",
    "baseline-browser-mapping": "^2.9.19",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cors": "^2.8.6",
    "enhanced-resolve": "^5.18.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "express": "^5.2.1",
    "get-tsconfig": "^4.13.1",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "jest-util": "^30.2.0",
    "jiti": "2.6.1",
    "jose": "^6.1.3",
    "jsdom": "~27.1.0",
    "jsonc-eslint-parser": "^2.4.2",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "markdownlint-cli2": "^0.22.1",
    "next": "^16.1.6",
    "oxlint": "^1.62.0",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.1",
    "tslib": "^2.8.1",
    "turbo": "^2.9.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "verdaccio": "^6.2.5",
    "vite": "^7.3.1",
    "vite-plugin-dts": "~4.5.4",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "html-encoding-sniffer": "^6.0.0"
  },
  "dependencies": {
    "@fumadocs/mdx-remote": "^1.4.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/analytics": "^1.6.1",
    "acorn": "^8.15.0",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint-config-next": "16.1.1",
    "fs-extra": "^11.3.3",
    "fumadocs-core": "16.4.3",
    "fumadocs-mdx": "14.2.4",
    "fumadocs-twoslash": "^3.1.12",
    "fumadocs-ui": "16.4.3",
    "glob": "^11.1.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.2",
    "motion": "^12.29.2",
    "next-themes": "^0.4.6",
    "panzoom": "^9.4.3",
    "postcss": "^8.5.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "twoslash": "^0.3.6"
  }
}
