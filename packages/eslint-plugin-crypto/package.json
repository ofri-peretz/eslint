{
  "name": "eslint-plugin-crypto",
  "version": "2.2.3",
  "deprecated": "eslint-plugin-crypto is deprecated. Use eslint-plugin-node-security instead \u2014 it includes all cryptography rules (weak ciphers/hashes, ECB mode, static IVs, insecure key derivation, timing-unsafe compare, insecure Math.random() for crypto, CryptoJS, native-crypto preference, and more).",
  "description": "[DEPRECATED \u2014 use eslint-plugin-node-security] Security-focused ESLint plugin for cryptographic best practices. All rules redistributed into eslint-plugin-node-security.",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./src/types/index.d.ts",
      "default": "./src/types/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint.d.ts",
      "default": "./src/oxlint.js"
    }
  },
  "author": "Ofri Peretz <ofriperetzdev@gmail.com>",
  "license": "MIT",
  "homepage": "https://eslint.interlace.tools/docs/security/plugin-crypto?utm_source=npm&utm_medium=referral&utm_campaign=eslint-plugin-crypto",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofri-peretz/eslint",
    "directory": "packages/eslint-plugin-crypto"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "dist/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "security",
    "crypto",
    "cryptography",
    "encryption",
    "hashing",
    "nodejs-crypto",
    "cve",
    "cwe",
    "owasp",
    "vulnerability",
    "llm-optimized",
    "ai-assistant",
    "auto-fix",
    "typescript",
    "marvin-attack",
    "timing-attack"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@interlace/eslint-devkit": "^1.2.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.46.2",
    "@typescript-eslint/rule-tester": "^8.46.2"
  },
  "scripts": {
    "build": "tsx ../../scripts/build-package.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/ofri-peretz/eslint"
  }
}
