{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/src",
    "declaration": true,
    "module": "Node16",
    "types": [
      "node"
    ],
    "composite": true,
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../eslint-devkit/tsconfig.lib.json"
    }
  ]
}
