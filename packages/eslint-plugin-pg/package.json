{
  "name": "eslint-plugin-pg",
  "version": "1.4.5",
  "description": "ESLint plugin with security and best practices rules for the pg Node.js driver",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint.d.ts",
      "default": "./src/oxlint.js"
    }
  },
  "author": "Ofri Peretz <ofriperetzdev@gmail.com>",
  "license": "MIT",
  "homepage": "https://eslint.interlace.tools/docs/security/plugin-pg?utm_source=npm&utm_medium=referral&utm_campaign=eslint-plugin-pg",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofri-peretz/eslint",
    "directory": "packages/eslint-plugin-pg"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "interlace-security",
    "pg",
    "postgres",
    "postgresql",
    "node-postgres",
    "security",
    "best-practices",
    "code-quality",
    "llm-optimized"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "pg": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@interlace/eslint-devkit": "^1.4.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.46.2",
    "@typescript-eslint/rule-tester": "^8.46.2",
    "pg": "^8.22.0"
  },
  "scripts": {
    "build": "tsx ../../scripts/build-package.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/ofri-peretz/eslint"
  }
}
