{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist/src",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "declaration": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__benchmarks__/**"
  ]
}
