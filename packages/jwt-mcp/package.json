{
  "name": "@interlace/jwt-mcp",
  "version": "0.1.0",
  "description": "MCP server for the @interlace/eslint-plugin-jwt ESLint plugin. Exposes list_rules, audit_file, find_rule_violations, suggest_fix over stdio. Built on @interlace/eslint-mcp-base.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.mjs",
  "bin": {
    "jwt-mcp": "./src/index.mjs"
  },
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "eslint",
    "static-analysis",
    "jwt",
    "interlace",
    "agent"
  ],
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "dependencies": {
    "@interlace/eslint-mcp-base": "*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}
