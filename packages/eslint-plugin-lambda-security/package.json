{
  "name": "eslint-plugin-lambda-security",
  "version": "1.2.6",
  "description": "Security-focused ESLint plugin for AWS Lambda and Middy applications. Detects insecure API Gateway responses, missing security headers, CORS misconfigurations, input validation issues, and more.",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./src/types/index.d.ts",
      "default": "./src/types/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint.d.ts",
      "default": "./src/oxlint.js"
    }
  },
  "author": "Ofri Peretz <ofriperetzdev@gmail.com>",
  "license": "MIT",
  "homepage": "https://eslint.interlace.tools/docs/security/plugin-lambda-security?utm_source=npm&utm_medium=referral&utm_campaign=eslint-plugin-lambda-security",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofri-peretz/eslint",
    "directory": "packages/eslint-plugin-lambda-security"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "interlace-security",
    "aws",
    "lambda",
    "aws-lambda",
    "middy",
    "api-gateway",
    "serverless",
    "security",
    "cors",
    "headers",
    "validation",
    "owasp",
    "cwe",
    "llm-optimized",
    "ai-assistant",
    "typescript",
    "static-analysis"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@interlace/eslint-devkit": "^1.4.1"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-lambda": {
      "optional": true
    },
    "@middy/core": {
      "optional": true
    },
    "@middy/http-cors": {
      "optional": true
    },
    "@middy/http-security-headers": {
      "optional": true
    },
    "@middy/validator": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.46.2",
    "@typescript-eslint/rule-tester": "^8.46.2"
  },
  "scripts": {
    "build": "tsx ../../scripts/build-package.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/ofri-peretz/eslint"
  }
}
