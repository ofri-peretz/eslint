{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "composite": true,
    "outDir": "./dist/src",
    "declaration": true,
    "types": [
      "node"
    ],
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "../eslint-devkit/tsconfig.lib.json"
    }
  ]
}
