{
  "name": "interlace-vscode",
  "displayName": "Interlace ESLint",
  "version": "0.1.0",
  "publisher": "interlace",
  "description": "Run the Interlace ESLint security suite from VS Code. Squiggles, code actions, and one-click MCP server boot for Claude Code / Cursor / GitHub Copilot. Roadmap item 6.2.",
  "license": "MIT",
  "private": false,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "keywords": ["eslint", "interlace", "security", "static-analysis", "mcp", "agent"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onCommand:interlace.audit",
    "onCommand:interlace.auditWorkspace",
    "onCommand:interlace.init",
    "onCommand:interlace.startMcp"
  ],
  "contributes": {
    "commands": [
      { "command": "interlace.audit",          "title": "Interlace: Audit Current File", "category": "Interlace" },
      { "command": "interlace.auditWorkspace", "title": "Interlace: Audit Workspace",     "category": "Interlace" },
      { "command": "interlace.init",           "title": "Interlace: Init (write eslint.config.mjs)", "category": "Interlace" },
      { "command": "interlace.startMcp",       "title": "Interlace: Start MCP Server for Plugin…",   "category": "Interlace" }
    ],
    "menus": {
      "editor/context": [
        { "command": "interlace.audit", "when": "resourceLangId in interlace.supportedLanguages", "group": "1_modification" }
      ],
      "explorer/context": [
        { "command": "interlace.auditWorkspace", "group": "navigation" }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Interlace",
      "properties": {
        "interlace.cliPath":          { "type": "string", "default": "interlace", "description": "Path to the `interlace` binary. Defaults to whatever is on PATH (e.g. installed via `npm i -g @interlace/cli`)." },
        "interlace.plugins":          { "type": "string", "default": "secure-coding,node-security,browser-security", "description": "Comma-separated plugins to enable, or 'all' for the full security fleet." },
        "interlace.failOn":           { "type": "string", "enum": ["error", "warning", "none"], "default": "warning", "description": "Severity at or above which findings are reported as VS Code errors." },
        "interlace.runOnSave":        { "type": "boolean", "default": true,  "description": "Run audit on file save." },
        "interlace.supportedLanguages": { "type": "array",  "default": ["javascript", "javascriptreact", "typescript", "typescriptreact"], "description": "Languages the extension activates for." }
      }
    }
  },
  "scripts": {
    "build":      "tsc -p ./",
    "watch":      "tsc -watch -p ./",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node":   "^25.8.0",
    "@types/vscode": "^1.120.0",
    "typescript":    "^6.0.3"
  }
}
