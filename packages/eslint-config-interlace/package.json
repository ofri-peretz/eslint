{
  "name": "@interlace/eslint-config",
  "version": "0.1.1",
  "description": "One-extends meta-config for the Interlace ESLint ecosystem. Composes the 9 flagship-hosting plugins (10 rules) and the full 19-plugin recommended preset (security + code-quality + React) into a single import. Replaces the manual 11-plugin compose documented in .agent/flagship-rules.md.",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "author": "Ofri Peretz <ofriperetzdev@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ofri-peretz/eslint/tree/main/packages/eslint-config-interlace#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofri-peretz/eslint",
    "directory": "packages/eslint-config-interlace"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "flat-config",
    "interlace",
    "interlace-security",
    "security",
    "owasp",
    "owasp-top-10",
    "react",
    "import",
    "code-quality",
    "meta-config",
    "shareable-config",
    "flagship",
    "recommended",
    "static-analysis"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsx ../../scripts/build-package.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@interlace/eslint-devkit": "^1.4.1",
    "eslint-plugin-browser-security": "^1.2.7",
    "eslint-plugin-conventions": "^4.2.1",
    "eslint-plugin-express-security": "^1.3.3",
    "eslint-plugin-import-next": "^2.3.8",
    "eslint-plugin-jwt": "^2.2.7",
    "eslint-plugin-lambda-security": "^1.2.7",
    "eslint-plugin-maintainability": "^3.0.7",
    "eslint-plugin-modernization": "^2.1.1",
    "eslint-plugin-modularity": "^2.1.1",
    "eslint-plugin-mongodb-security": "^8.2.5",
    "eslint-plugin-nestjs-security": "^1.2.5",
    "eslint-plugin-node-security": "^4.4.2",
    "eslint-plugin-operability": "^3.0.9",
    "eslint-plugin-pg": "^1.4.7",
    "eslint-plugin-react-a11y": "^2.1.7",
    "eslint-plugin-react-features": "^1.2.3",
    "eslint-plugin-reliability": "^3.1.5",
    "eslint-plugin-secure-coding": "^3.3.3",
    "eslint-plugin-vercel-ai-security": "^1.3.7"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "private": true
}