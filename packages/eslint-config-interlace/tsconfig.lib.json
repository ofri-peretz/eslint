{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "sourceMap": false,
    "composite": true,
    "outDir": "./dist/src",
    "declaration": true,
    "types": [
      "node"
    ],
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "references": [
    { "path": "../eslint-devkit/tsconfig.lib.json" },
    { "path": "../eslint-plugin-browser-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-conventions/tsconfig.lib.json" },
    { "path": "../eslint-plugin-express-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-import-next/tsconfig.lib.json" },
    { "path": "../eslint-plugin-jwt/tsconfig.lib.json" },
    { "path": "../eslint-plugin-lambda-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-maintainability/tsconfig.lib.json" },
    { "path": "../eslint-plugin-modernization/tsconfig.lib.json" },
    { "path": "../eslint-plugin-modularity/tsconfig.lib.json" },
    { "path": "../eslint-plugin-mongodb-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-nestjs-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-node-security/tsconfig.lib.json" },
    { "path": "../eslint-plugin-operability/tsconfig.lib.json" },
    { "path": "../eslint-plugin-pg/tsconfig.lib.json" },
    { "path": "../eslint-plugin-react-a11y/tsconfig.lib.json" },
    { "path": "../eslint-plugin-react-features/tsconfig.lib.json" },
    { "path": "../eslint-plugin-reliability/tsconfig.lib.json" },
    { "path": "../eslint-plugin-secure-coding/tsconfig.lib.json" },
    { "path": "../eslint-plugin-vercel-ai-security/tsconfig.lib.json" }
  ]
}
