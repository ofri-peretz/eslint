{
  "name": "eslint-plugin-import-next",
  "version": "2.3.7",
  "description": "Drop-in replacement for eslint-plugin-import. 100x faster no-cycle detection, AI-optimized fixes, zero config migration.",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./src/types/index.d.ts",
      "default": "./src/types/index.js"
    },
    "./oxlint": {
      "types": "./src/oxlint.d.ts",
      "default": "./src/oxlint.js"
    }
  },
  "author": "Ofri Peretz <ofriperetzdev@gmail.com>",
  "license": "MIT",
  "homepage": "https://eslint.interlace.tools/docs/quality/plugin-import-next?utm_source=npm&utm_medium=referral&utm_campaign=eslint-plugin-import-next",
  "repository": {
    "type": "git",
    "url": "https://github.com/ofri-peretz/eslint",
    "directory": "packages/eslint-plugin-import-next"
  },
  "bugs": {
    "url": "https://github.com/ofri-peretz/eslint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "interlace-quality",
    "eslint-plugin-import",
    "eslint-plugin-import-alternative",
    "import",
    "imports",
    "no-cycle",
    "circular-dependencies",
    "import-order",
    "modules",
    "module-resolution",
    "commonjs",
    "esm",
    "llm-optimized",
    "ai-assistant",
    "auto-fix",
    "typescript",
    "static-analysis",
    "mcp",
    "agentic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@interlace/eslint-devkit": "^1.4.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.46.2",
    "@typescript-eslint/rule-tester": "^8.46.2"
  },
  "scripts": {
    "build": "tsx ../../scripts/build-package.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/ofri-peretz/eslint"
  }
}
