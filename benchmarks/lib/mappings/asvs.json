{
  "$id": "https://benchmarks.interlace.dev/mappings/asvs-4.0.3.json",
  "title": "OWASP Application Security Verification Standard (ASVS v4.0.3)",
  "description": "Top-level controls. The full ASVS has 14 sections × 3 levels (L1/L2/L3) = ~280 controls. This file enumerates what we crosswalk against; rule-level mappings live in each rule's meta.asvs.",
  "version": "4.0.3",
  "lastReviewed": "2026-05-09",
  "sections": {
    "V1":  { "name": "Architecture, Design and Threat Modeling", "lintApplicability": "low" },
    "V2":  { "name": "Authentication", "lintApplicability": "medium", "examplePlugins": ["jwt", "express-security"] },
    "V3":  { "name": "Session Management", "lintApplicability": "medium" },
    "V4":  { "name": "Access Control", "lintApplicability": "medium", "examplePlugins": ["nestjs-security", "express-security"] },
    "V5":  { "name": "Validation, Sanitization and Encoding", "lintApplicability": "high", "examplePlugins": ["secure-coding", "vercel-ai-security", "browser-security"] },
    "V6":  { "name": "Stored Cryptography", "lintApplicability": "high", "examplePlugins": ["crypto"] },
    "V7":  { "name": "Error Handling and Logging", "lintApplicability": "high", "examplePlugins": ["secure-coding"] },
    "V8":  { "name": "Data Protection", "lintApplicability": "medium" },
    "V9":  { "name": "Communications", "lintApplicability": "medium", "examplePlugins": ["node-security"] },
    "V10": { "name": "Malicious Code", "lintApplicability": "high", "examplePlugins": ["secure-coding"] },
    "V11": { "name": "Business Logic", "lintApplicability": "low" },
    "V12": { "name": "Files and Resources", "lintApplicability": "high", "examplePlugins": ["node-security", "lambda-security"] },
    "V13": { "name": "API and Web Service", "lintApplicability": "high", "examplePlugins": ["express-security", "nestjs-security", "vercel-ai-security"] },
    "V14": { "name": "Configuration", "lintApplicability": "medium" }
  },
  "levelDefinitions": {
    "L1": "Opportunistic — applications protected against opportunistic attacks (low-effort attackers, automated scanning).",
    "L2": "Standard — most applications. Protects against most application risks. Recommended baseline.",
    "L3": "Advanced — high-value, high-risk applications (financial, healthcare, government). Defense-in-depth, exhaustive."
  },
  "exampleRuleMappings": {
    "_comment": "Seed mappings for the most common rule families. Per-rule meta.asvs overrides these.",
    "secure-coding/no-hardcoded-credentials": [{ "section": "V6", "control": "V6.4.1", "level": "L1" }, { "section": "V14", "control": "V14.3.1", "level": "L1" }],
    "secure-coding/no-eval": [{ "section": "V5", "control": "V5.2.4", "level": "L1" }, { "section": "V10", "control": "V10.3.2", "level": "L2" }],
    "pg/no-unsafe-query": [{ "section": "V5", "control": "V5.3.4", "level": "L1" }],
    "mongodb-security/no-unsafe-query": [{ "section": "V5", "control": "V5.3.4", "level": "L1" }],
    "browser-security/no-innerhtml": [{ "section": "V5", "control": "V5.3.3", "level": "L1" }],
    "jwt/no-algorithm-none": [{ "section": "V3", "control": "V3.5.3", "level": "L2" }, { "section": "V6", "control": "V6.2.1", "level": "L2" }],
    "vercel-ai-security/no-unsafe-output-handling": [{ "section": "V5", "control": "V5.3.3", "level": "L2" }, { "section": "V13", "control": "V13.2.1", "level": "L2" }],
    "secure-coding/no-shell-injection":         [{ "section": "V5", "control": "V5.3.8", "level": "L1" }, { "section": "V12", "control": "V12.3.1", "level": "L2" }],
    "secure-coding/no-sql-injection":           [{ "section": "V5", "control": "V5.3.4", "level": "L1" }],
    "secure-coding/no-unsafe-deserialization":  [{ "section": "V5", "control": "V5.5.1", "level": "L1" }, { "section": "V10", "control": "V10.3.2", "level": "L2" }],
    "secure-coding/no-prototype-pollution":     [{ "section": "V5", "control": "V5.5.4", "level": "L2" }],
    "secure-coding/no-redos":                   [{ "section": "V5", "control": "V5.2.5", "level": "L2" }],
    "secure-coding/no-insecure-comparison":     [{ "section": "V6", "control": "V6.2.7", "level": "L2" }],
    "secure-coding/no-insecure-randomness":     [{ "section": "V6", "control": "V6.3.1", "level": "L1" }, { "section": "V6", "control": "V6.3.2", "level": "L2" }],
    "secure-coding/no-leaked-error-message":    [{ "section": "V7", "control": "V7.4.1", "level": "L1" }],
    "secure-coding/no-stack-trace-exposure":    [{ "section": "V7", "control": "V7.4.1", "level": "L1" }],
    "node-security/no-path-traversal":          [{ "section": "V12", "control": "V12.3.1", "level": "L1" }, { "section": "V12", "control": "V12.3.2", "level": "L2" }],
    "node-security/no-child-process-shell-injection": [{ "section": "V5", "control": "V5.3.8", "level": "L1" }],
    "node-security/no-ssrf":                    [{ "section": "V12", "control": "V12.6.1", "level": "L2" }, { "section": "V13", "control": "V13.2.6", "level": "L2" }],
    "node-security/no-insecure-tls":            [{ "section": "V9", "control": "V9.1.1", "level": "L1" }, { "section": "V9", "control": "V9.2.1", "level": "L2" }],
    "node-security/no-dynamic-require":         [{ "section": "V10", "control": "V10.3.2", "level": "L2" }, { "section": "V14", "control": "V14.2.1", "level": "L2" }],
    "browser-security/no-document-write":       [{ "section": "V5", "control": "V5.3.3", "level": "L1" }],
    "browser-security/no-target-blank-noopener": [{ "section": "V14", "control": "V14.4.6", "level": "L2" }],
    "browser-security/no-permissive-cors":      [{ "section": "V13", "control": "V13.2.5", "level": "L2" }, { "section": "V14", "control": "V14.5.3", "level": "L1" }],
    "browser-security/no-postmessage-wildcard": [{ "section": "V14", "control": "V14.4.6", "level": "L2" }],
    "express-security/no-permissive-cors":      [{ "section": "V13", "control": "V13.2.5", "level": "L2" }, { "section": "V14", "control": "V14.5.3", "level": "L1" }],
    "express-security/no-skipped-auth-middleware": [{ "section": "V4", "control": "V4.1.1", "level": "L1" }, { "section": "V4", "control": "V4.2.1", "level": "L1" }],
    "express-security/require-helmet":          [{ "section": "V14", "control": "V14.4.1", "level": "L1" }, { "section": "V14", "control": "V14.4.5", "level": "L1" }],
    "lambda-security/no-secret-logging":        [{ "section": "V7", "control": "V7.1.1", "level": "L1" }, { "section": "V8", "control": "V8.3.1", "level": "L1" }],
    "lambda-security/no-unbounded-presigned-url": [{ "section": "V12", "control": "V12.4.1", "level": "L2" }],
    "mongodb-security/no-unsafe-query":         [{ "section": "V5", "control": "V5.3.4", "level": "L1" }],
    "mongodb-security/no-find-without-projection": [{ "section": "V8", "control": "V8.1.4", "level": "L2" }],
    "nestjs-security/no-public-decorator-on-sensitive-route": [{ "section": "V4", "control": "V4.1.5", "level": "L1" }, { "section": "V4", "control": "V4.2.1", "level": "L1" }],
    "vercel-ai-security/no-prompt-injection-pattern": [{ "section": "V5", "control": "V5.1.3", "level": "L2" }, { "section": "V13", "control": "V13.2.1", "level": "L2" }],
    "vercel-ai-security/require-request-timeout": [{ "section": "V13", "control": "V13.2.1", "level": "L2" }],
    "crypto/no-md5":                            [{ "section": "V6", "control": "V6.2.5", "level": "L1" }],
    "crypto/no-sha1":                           [{ "section": "V6", "control": "V6.2.5", "level": "L1" }],
    "crypto/no-static-iv":                      [{ "section": "V6", "control": "V6.2.6", "level": "L2" }],
    "crypto/no-static-salt":                    [{ "section": "V6", "control": "V6.2.6", "level": "L2" }],
    "jwt/no-weak-secret":                       [{ "section": "V3", "control": "V3.5.3", "level": "L2" }, { "section": "V6", "control": "V6.4.1", "level": "L2" }],
    "jwt/no-skip-verification":                 [{ "section": "V3", "control": "V3.5.3", "level": "L2" }],
    "pg/no-unsafe-query":                       [{ "section": "V5", "control": "V5.3.4", "level": "L1" }],
    "pg/no-hardcoded-credentials":              [{ "section": "V6", "control": "V6.4.1", "level": "L1" }, { "section": "V14", "control": "V14.3.1", "level": "L1" }],
    "pg/no-insecure-ssl":                       [{ "section": "V9", "control": "V9.1.1", "level": "L1" }],
    "pg/no-transaction-on-pool":                [{ "section": "V11", "control": "V11.1.1", "level": "L2" }],
    "pg/prevent-double-release":                [{ "section": "V11", "control": "V11.1.1", "level": "L2" }]
  }
}
