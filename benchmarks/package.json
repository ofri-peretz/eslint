{
  "name": "@interlace/benchmarks",
  "version": "1.0.0",
  "private": true,
  "description": "Reproducible benchmarks for ESLint plugins — performance, FN/FP accuracy, and AI security",
  "type": "module",
  "scripts": {
    "ilb:perf-import": "tsx suites/ilb-perf-import/run.js",
    "ilb:juliet": "tsx suites/ilb-juliet/run.ts",
    "ilb:arena": "tsx suites/ilb-arena/run.js",
    "ilb:arena-quality": "tsx suites/ilb-arena-quality/run.js",
    "ilb:ai": "tsx suites/ilb-ai/run.js",
    "ilb:validate-fixtures": "tsx ../scripts/ilb-validate-fixtures.ts",
    "ilb:validate-fixtures:strict": "tsx ../scripts/ilb-validate-fixtures.ts --strict",
    "ilb:validate-results": "tsx ../scripts/ilb-validate-results.ts",
    "ilb:validate-results:strict": "tsx ../scripts/ilb-validate-results.ts --strict",
    "ilb:history-backfill": "tsx ../scripts/ilb-history-backfill.ts",
    "ilb:history-backfill:dry": "tsx ../scripts/ilb-history-backfill.ts --dry-run",
    "ilb:severity-audit": "tsx ../scripts/ilb-severity-audit.ts",
    "ilb:promotion-gate": "tsx ../scripts/ilb-promotion-gate.ts",
    "ilb:promotion-gate:explain": "tsx ../scripts/ilb-promotion-gate.ts --explain",
    "ilb:all": "tsx scripts/run-benchmark.js --all",
    "generate:perf-import": "node scripts/generate-fixtures.js perf-import",
    "generate:juliet": "node scripts/generate-fixtures.js juliet",
    "generate:all": "node scripts/generate-fixtures.js --all"
  },
  "keywords": [
    "eslint",
    "benchmark",
    "performance",
    "security",
    "interlace"
  ],
  "author": "Ofri Peretz",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.0.1",
    "dotenv": "^17.2.4",
    "eslint-plugin-browser-security": "*",
    "eslint-plugin-conventions": "*",
    "eslint-plugin-crypto": "*",
    "eslint-plugin-express-security": "*",
    "eslint-plugin-import-next": "*",
    "eslint-plugin-jwt": "*",
    "eslint-plugin-lambda-security": "*",
    "eslint-plugin-maintainability": "*",
    "eslint-plugin-modernization": "*",
    "eslint-plugin-modularity": "*",
    "eslint-plugin-mongodb-security": "*",
    "eslint-plugin-nestjs-security": "*",
    "eslint-plugin-node-security": "*",
    "eslint-plugin-operability": "*",
    "eslint-plugin-pg": "*",
    "eslint-plugin-reliability": "*",
    "eslint-plugin-secure-coding": "*",
    "eslint-plugin-vercel-ai-security": "*"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@microsoft/eslint-plugin-sdl": "^1.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.12.2",
    "eslint-plugin-jsdoc": "^62.5.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-security-node": "^1.1.4",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
