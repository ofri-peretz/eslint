#!/bin/bash
# Skip silently if no staged changes in packages (docs, configs don't need checks).
if ! git diff --cached --name-only | grep -q "^packages/"; then
  exit 0
fi

echo "🚀 Running pre-commit checks..."

# Lint: oxlint runs across the whole tree in <300ms — fast enough that
# scoping to affected packages isn't worth the complexity.
echo "📝 Running oxlint..."
if ! npm run --silent oxlint; then
  echo "❌ oxlint failed"
  echo "💡 Run 'npm run oxlint' to see full output"
  exit 1
fi

# Tests: scope to packages affected vs origin/main. Falls back to running
# the full graph if origin/main isn't available locally.
echo "🧪 Running tests (affected)..."
if git rev-parse --verify --quiet origin/main >/dev/null; then
  TEST_FILTER="--filter=...[origin/main]"
else
  TEST_FILTER=""
fi

if ! npx --no turbo run test $TEST_FILTER --output-logs=errors-only; then
  echo "❌ Tests failed"
  echo "💡 Run 'npx turbo run test $TEST_FILTER' to see full output"
  exit 1
fi

echo "✅ All checks passed!"
exit 0
