{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/sync-plugin-stats.ts && tsx scripts/sync-tweet-cache.ts && next build",
    "dev": "tsx scripts/sync-plugin-stats.ts && next dev --port 3000",
    "sync-stats": "tsx scripts/sync-plugin-stats.ts",
    "sync-tweets": "tsx scripts/sync-tweet-cache.ts",
    "sync-devto": "tsx scripts/sync-devto-cache.ts",
    "sync:agents": "tsx ../../scripts/sync-agents.ts",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:css": "vitest run src/__tests__/tailwind-classes.test.ts",
    "test:a11y": "playwright test e2e/a11y.spec.ts e2e/a11y-tree.spec.ts --project=chromium --reporter=list",
    "a11y:report": "tsx scripts/a11y-summary.ts",
    "a11y:gradients": "tsx scripts/a11y-gradient-sweep.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fumadocs/mdx-remote": "^1.4.10",
    "@interlace/benchmarks": "*",
    "@interlace/ui": "*",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/postcss": "^4.2.4",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.9.1",
    "fumadocs-mdx": "^15.0.8",
    "fumadocs-ui": "^16.9.1",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "next": "^16.2.4",
    "posthog-js": "^1.376.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-tweet": "^3.3.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "axe-core": "^4.11.4",
    "vitest": "^2.1.0"
  }
}
