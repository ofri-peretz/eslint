{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsx scripts/sync-plugin-stats.ts && tsx scripts/sync-tweet-cache.ts && next build",
    "dev": "tsx scripts/sync-plugin-stats.ts && next dev --port 3000",
    "sync-stats": "tsx scripts/sync-plugin-stats.ts",
    "sync-tweets": "tsx scripts/sync-tweet-cache.ts",
    "sync-devto": "tsx scripts/sync-devto-cache.ts",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:css": "vitest run src/__tests__/tailwind-classes.test.ts"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-beta.6",
    "@fumadocs/mdx-remote": "^1.4.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.5.0",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-ui": "^16.5.0",
    "mermaid": "^11.12.2",
    "motion": "^12.29.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-tweet": "^3.3.0",
    "tailwind-merge": "^3.4.0",
    "next": "^16.1.6",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0"
  }
}