# PostHog (ANALYTICS_PHILOSOPHY.md)
# Project token from the Interlace PostHog project (id 428927).
# Leave empty to disable analytics; the app renders identically without it.
NEXT_PUBLIC_POSTHOG_KEY=

# Optional: set to `1` to disable session replay specifically. Web vitals,
# error capture, and feature flags remain on.
NEXT_PUBLIC_POSTHOG_DISABLE_REPLAY=
