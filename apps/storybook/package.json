{
  "name": "@interlace/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "test-storybook": "test-storybook --url http://localhost:6006",
    "test-storybook:ci": "concurrently -k -s first -n SB,TEST \"http-server storybook-static -p 6006 -s\" \"wait-on tcp:6006 && test-storybook --url http://localhost:6006\""
  },
  "dependencies": {
    "@interlace/ui": "*",
    "lucide-react": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.1.2",
    "http-server": "^14.1.1",
    "playwright": "^1.49.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.10"
  }
}
